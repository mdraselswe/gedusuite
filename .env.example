DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require&channel_binding=require"
NEXTAUTH_SECRET="replace-with-a-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth client — used for both "Sign in with Google" and each user's
# personal backup connection (callback: /api/google/personal/callback).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional: company-level Google service account, used to upload JSON
# backups to Drive (Settings → Backup). Paste the full downloaded service
# account key JSON as a single-line string. Share the target Drive folder
# with the service account's client_email, or uploads will fail (service
# accounts have no Drive storage of their own).
GOOGLE_SERVICE_ACCOUNT_JSON=""

# Shared secret checked by the scheduled backup crons (/api/cron/backup,
# /api/cron/personal-backup). Must match the Authorization header Vercel
# Cron sends.
CRON_SECRET=""

# Encrypts stored Google OAuth tokens (personal backup connections). Falls
# back to NEXTAUTH_SECRET if unset — set a distinct value in production.
BACKUP_ENCRYPTION_KEY=""

# Optional: Prisma connection pool tuning (defaults: 10 / 30).
# PRISMA_CONNECTION_LIMIT="10"
# PRISMA_POOL_TIMEOUT="30"
